# ── Application ──────────────────────────────────
DEBUG=false

# ── PostgreSQL ───────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/ai_interview

# ── Redis ────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── MinIO (S3-compatible) ────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_RESUMES=resumes
MINIO_USE_SSL=false

# ── CORS ─────────────────────────────────────────
CORS_ORIGINS=["http://localhost:5173"]

# ── Encryption Key (generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())") ──
ENCRYPTION_KEY=

# ── LLM Config ───────────────────────────────────
# Provider: openai | anthropic | deepseek
DEFAULT_LLM_PROVIDER=openai
DEFAULT_LLM_MODEL=gpt-4o

# OpenAI / DeepSeek (OpenAI-compatible)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic
ANTHROPIC_API_KEY=
